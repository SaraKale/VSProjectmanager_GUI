<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="420"
        xmlns:res="clr-namespace:VSProjectManager_GUI.Resources"
        x:Class="VSProjectManager_GUI.InputFileListBox"
        Width="500" Height="420"
        Title="{x:Static res:Resources.InputfilepathWindow}">

    <StackPanel Margin="15" Spacing="10">
        <!-- 请输入完整路径，一行一个，也可以拖放文件到这里。 -->
        <TextBlock Text="{x:Static res:Resources.InputFileListTip}"/>
        <!-- 滚动条 -->
        <ScrollViewer Height="300"
                      VerticalScrollBarVisibility="Auto">
            <!-- 文本框 -->
         <TextBox Name="BatchFileListBox"
                  AcceptsReturn="True"
                  TextWrapping="NoWrap"/>
        </ScrollViewer>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="20">
            <!-- 添加按钮 -->
            <Button Name="OpenFileButton" Content="{x:Static res:Resources.InputFileListText}" Width="130" Height="35" Margin="0,0,0,0"
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Click="BatchFileClick" />

        </StackPanel>

    </StackPanel>

</Window>
